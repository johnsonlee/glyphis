{
  "name": "glyph",
  "version": "0.1.0",
  "description": "A cross-platform mobile app framework with near-native performance",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-runtime.ts"
  },
  "scripts": {
    "test": "bun test --coverage",
    "dev": "bun run src/devserver/index.ts",
    "build": "bun build src/index.ts --outdir dist --target browser"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "dependencies": {
    "puppeteer": "^24.40.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0"
  }
}
