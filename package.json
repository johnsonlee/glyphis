  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {
    "jsc-android": "^250231.0.0",
    "puppeteer": "^24.40.0",
    "solid-js": "^1.9.12",
    "yoga-layout": "^3.2.1"
  }
}
