{
  "name": "glyphis",
  "version": "0.1.0",
  "description": "A cross-platform mobile app framework with near-native performance",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
